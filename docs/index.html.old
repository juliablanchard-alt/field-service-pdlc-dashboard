2026-05-06", "health": "Not Started", "health_comments": "-", "health_status": "Not Started", "name": "[264] Agentic SLA Milestones GA", "number": "51"}, {"end_date": "2026-06-03", "health": "Not Started", "health_comments": "-", "health_status": "Not Started", "name": "[264] SLA Skill/Action for Service Rep Assistant", "number": "52"}], "name": "[264] Proactive SLA Management"}, {"epics": [{"end_date": "2026-05-08", "health": "Not Started", "health_comments": "-", "health_status": "Not Started", "name": "Q4 Testing [264] Migrate 50 customers to re-architected backend", "number": "-"}, {"end_date": "2026-06-03", "health": "Not Started", "health_comments": "-", "health_status": "Not Started", "name": "[264] Re-architecture dark launch", "number": "2"}], "name": "[264] Migrate 50 customers to re-architected backend"}], "subcloud": "FY27 SC M7 Deliver Agentic Service Rep Experience - SLA", "target_release": "264", "theme": "\u26ab Not Prioritized"}, {"health": "Not Started", "health_comments": "5/13 - 264 patch will be GA for SRA Case|Messaging|Voice - scope definition and LoC in progress", "id": "a1fEE0000003440YAA", "name": "[264] Service Rep Assistant", "portfolio": "FY27 SC M7 Deliver Agentic Service Rep Experience - SRA", "program_manager": "TJ Stephen", "projects": [{"epics": [{"end_date": "2026-05-08", "health": "Not Started", "health_comments": "-", "health_status": "Not Started", "name": "Q4 Testing [264] Next Gen Agent Migration", "number": "-"}], "name": "[264] Next Gen Agent Migration"}, {"epics": [{"end_date": "2026-05-08", "health": "Not Started", "health_comments": "-", "health_status": "Not Started", "name": "Q4 Testing [264] Real-Time Intelligence at Case Open", "number": "-"}, {"end_date": "2026-06-03", "health": "On Track", "health_comments": "-", "health_status": "On Track", "name": "[264][SF/SPA] Record Companion Runtime Decoupling with SRA", "number": "-"}, {"end_date": "2026-06-03", "health": "On Track", "health_comments": "-", "health_status": "On Track", "name": "[264][SF/SPA] Migrate ServicePlanSkill to Actor V2 Framework", "number": "-"}, {"end_date": "2026-06-03", "health": "On Track", "health_comments": "-", "health_status": "On Track", "name": "[264][SF/SPA] SRA Implement Per-Channel Summary Plan Toggle \u0026 Auto Run", "number": "-"}, {"end_date": "2026-06-03", "health": "On Track", "health_comments": "-", "health_status": "On Track", "name": "[264][SF/SPA] SRA - Summary Plan to Message History for Case AE", "number": "-"}], "name": "[264] SRA Adaptive Experience"}, {"epics": [{"end_date": "2026-05-08", "health": "Not Started", "health_comments": "-", "health_status": "Not Started", "name": "Q4 Testing [264] Enhanced Plan Grounding \u0026 Personalization", "number": "-"}, {"end_date": "2026-05-06", "health": "Unknown", "health_comments": "-", "health_status": "Canceled", "name": "[264] [Soba] Service Assistant Plan generation on case open", "number": "1"}, {"end_date": "2026-04-02", "health": "Not Started", "health_comments": "-", "health_status": "Not Started", "name": "[264] [SOX] Ground on Agent Builder Profile Details (Description, Role, Company)", "number": "1"}], "name": "[264] Enhanced Plan Grounding \u0026 Personalization"}, {"epics": [{"end_date": "2026-06-03", "health": "Not Started", "health_comments": "-", "health_status": "Not Started", "name": "[264][SF/SPA] SRA - URL Display and Clickability in Guidance Plans", "number": "-"}], "name": "[264] SRA Guidance Plan Experience"}, {"epics": [{"end_date": null, "health": "Unknown", "health_comments": "-", "health_status": "-", "name": "-", "number": "-"}], "name": "[264] Service Plan Generation"}, {"epics": [{"end_date": null, "health": "Unknown", "health_comments": "-", "health_status": "-", "name": "-", "number": "-"}], "name": "[264] Service Insights \u0026 Multi-Channel Analytics"}, {"epics": [{"end_date": null, "health": "Unknown", "health_comments": "-", "health_status": "-", "name": "-", "number": "-"}], "name": "[264] Model Expansion \u0026 Continuous Optimization"}, {"epics": [{"end_date": "2026-06-03", "health": "Not Started", "health_comments": "-", "health_status": "Not Started", "name": "[264][SF/SPA] Service Assistant Refinement Work", "number": "1"}], "name": "[264] SRA Trust"}], "subcloud": "FY27 SC M7 Deliver Agentic Service Rep Experience - SRA", "target_release": "264", "theme": "\u26ab Not Prioritized"}, {"health": "On Track", "health_comments": "5/26 - Singularity in migrations in progress, awaiting an update from D360 on when abstract data objects will be supported so we can migrate knowledge data kits.  No 264 Use Cases were committed coming out of D360 planning, reviewing with them to see what options we have.", "id": "a1fEE0000003ltdYAA", "name": "[264] DCPF (Data Cloud Powered Features)", "portfolio": "FY27 SC M9 Product Investments to Drive Higher Adoption \u0026 NNAOV", "program_manager": "Nicole Persinger", "projects": [], "subcloud": "FY27 SC M9 Product Investments to Drive Higher Adoption \u0026 NNAOV", "target_release": "264", "theme": "-"}, {"health": "Not Started", "health_comments": "-", "id": "a1fEE00000034IPYAY", "name": "[264] Day 0 Initial Onboarding", "portfolio": "FY27 SC M9 Product Investments to Drive Higher Adoption \u0026 NNAOV", "program_manager": "Nicole Persinger", "projects": [{"epics": [{"end_date": null, "health": "Unknown", "health_comments": "-", "health_status": "-", "name": "-", "number": "-"}], "name": "[264] Initial Onboarding Solution"}, {"epics": [{"end_date": null, "health": "Unknown", "health_comments": "-", "health_status": "-", "name": "-", "number": "-"}], "name": "[264] Feature Bundle: Get Started with Service Cloud"}], "subcloud": "FY27 SC M9 Product Investments to Drive Higher Adoption \u0026 NNAOV", "target_release": "264", "theme": "-"}];

        function toggleProgram(header) {
            header.classList.toggle('collapsed');
            const content = header.nextElementSibling;
            content.classList.toggle('hidden');
        }

        // Global filter state and functions (must be outside DOMContentLoaded)
        let currentStatusFilter = 'all';
        let currentMonthFilter = 'all';
        let portfolioCheckboxes = null;  // Global reference to portfolio checkboxes

        // Helper function to map release number to freeze month
        function mapReleaseToFreezeMonth(releaseNumber) {
            if (!releaseNumber || !releaseNumber.match(/^\d+$/)) return null;
            const releaseNum = parseInt(releaseNumber);
            const baseRelease = 262;
            const baseYear = 2026;
            const baseMonth = 4;
            const releasesDiff = (releaseNum - baseRelease) / 2;
            const monthsOffset = releasesDiff * 4;
            const totalMonths = baseMonth - 1 + monthsOffset;
            const year = baseYear + Math.floor(totalMonths / 12);
            const month = (totalMonths % 12) + 1;
            return `${year}-${String(month).padStart(2, '0')}`;
        }

        function applyAllFilters(selectedPortfolios, statusFilter, monthFilter) {
            console.log('=== APPLY FILTERS ===');
            console.log('Portfolios:', selectedPortfolios, 'Status:', statusFilter, 'Month:', monthFilter);

            let visibleCount = 0;
            document.querySelectorAll('.programs-table tbody tr').forEach(row => {
                const portfolio = row.dataset.portfolio;
                const healthBadge = row.querySelector('.health-badge span:last-child');
                const health = healthBadge ? healthBadge.textContent.toLowerCase() : '';
                const targetRelease = row.dataset.targetRelease;

                const portfolioMatch = selectedPortfolios.includes('all') || selectedPortfolios.includes(portfolio);

                let statusMatch = statusFilter === 'all';
                if (!statusMatch) {
                    if (statusFilter === 'on-track' && health.includes('on track')) statusMatch = true;
                    else if (statusFilter === 'not-started' && health.includes('not started')) statusMatch = true;
                    else if (statusFilter === 'watch' && health.includes('watch')) statusMatch = true;
                    else if (statusFilter === 'blocked' && health.includes('blocked')) statusMatch = true;
                }

                let monthMatch = monthFilter === 'all';
                if (!monthMatch && targetRelease) {
                    const freezeMonth = mapReleaseToFreezeMonth(targetRelease);
                    if (visibleCount < 3) console.log(`Release ${targetRelease} -> ${freezeMonth} vs ${monthFilter}`);
                    monthMatch = freezeMonth === monthFilter;
                }

                const shouldShow = portfolioMatch && statusMatch && monthMatch;
                row.style.display = shouldShow ? '' : 'none';
                if (shouldShow) visibleCount++;
            });

            console.log('Visible:', visibleCount);
            console.log('Filter state - Portfolios:', selectedPortfolios, 'Status:', statusFilter, 'Month:', monthFilter);

            document.querySelectorAll('.program-section').forEach(section => {
                const portfolio = section.dataset.portfolio;
                const health = (section.dataset.health || '').toLowerCase();
                const targetRelease = section.dataset.targetRelease;
                const programName = section.dataset.program;

                // Apply same AND logic as table rows
                const portfolioMatch = selectedPortfolios.includes('all') || selectedPortfolios.includes(portfolio);

                let statusMatch = statusFilter === 'all';
                if (!statusMatch) {
                    if (statusFilter === 'on-track' && health.includes('on track')) statusMatch = true;
                    else if (statusFilter === 'not-started' && health.includes('not started')) statusMatch = true;
                    else if (statusFilter === 'watch' && health.includes('watch')) statusMatch = true;
                    else if (statusFilter === 'blocked' && health.includes('blocked')) statusMatch = true;
                }

                let monthMatch = monthFilter === 'all';
                if (!monthMatch && targetRelease) {
                    const freezeMonth = mapReleaseToFreezeMonth(targetRelease);
                    monthMatch = freezeMonth === monthFilter;
                }

                const shouldShow = portfolioMatch && statusMatch && monthMatch;

                // Debug HR Service specifically
                if (programName && programName.includes('HR Service')) {
                    console.log('HR Service Debug:', {
                        programName,
                        portfolio,
                        health,
                        portfolioMatch,
                        statusMatch,
                        monthMatch,
                        shouldShow
                    });
                }

                section.style.display = shouldShow ? 'block' : 'none';
            });
            if (typeof updateStatsCards === 'function') updateStatsCards();
        }

        // Wait for DOM to be ready
        document.addEventListener('DOMContentLoaded', function() {

        function clearFilters() {
            const programSelect = document.getElementById('programSelect');
            const searchBox = document.getElementById('searchBox');
            const staleSelect = document.getElementById('staleSelect');

            if (programSelect) programSelect.value = '';
            if (searchBox) searchBox.value = '';
            if (staleSelect) staleSelect.value = '';

            // Reset multi-select to "All"
            if (typeof portfolioCheckboxes !== 'undefined' && portfolioCheckboxes) {
                portfolioCheckboxes.forEach(cb => {
                    cb.checked = cb.value === 'all';
                });
                updatePortfolioDisplay();
            }

            document.querySelectorAll('.release-pill').forEach(pill => {
                pill.classList.remove('active');
            });
            document.querySelector('.release-pill[data-month="all"]').classList.add('active');

            document.querySelectorAll('.program-section').forEach(section => {
                section.style.display = 'block';
            });
        }

        // Custom multi-select portfolio filter
        const portfolioMultiSelect = document.getElementById('portfolioMultiSelect');
        if (!portfolioMultiSelect) {
            console.error('portfolioMultiSelect not found - skipping portfolio filter setup');
        } else {
            const portfolioDisplay = portfolioMultiSelect.querySelector('.multiselect-display');
            const portfolioDropdown = portfolioMultiSelect.querySelector('.multiselect-dropdown');
            const portfolioText = portfolioMultiSelect.querySelector('.multiselect-text');
            portfolioCheckboxes = portfolioMultiSelect.querySelectorAll('input[type="checkbox"]');  // Assign to global
            const allCheckbox = portfolioMultiSelect.querySelector('input[value="all"]');

        // Toggle dropdown
        if (portfolioDisplay) {
            portfolioDisplay.addEventListener('click', function(e) {
                e.stopPropagation();
                portfolioDropdown.style.display = portfolioDropdown.style.display === 'none' ? 'block' : 'none';
            });
        }

        // Close dropdown when clicking outside
        if (portfolioMultiSelect && portfolioDropdown) {
            document.addEventListener('click', function(e) {
                if (!portfolioMultiSelect.contains(e.target)) {
                    portfolioDropdown.style.display = 'none';
                }
            });
        }

        // Update filter when checkboxes change
        if (portfolioCheckboxes && portfolioCheckboxes.length > 0) {
            portfolioCheckboxes.forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                if (this.value === 'all' && this.checked) {
                    // Uncheck all others when "All" is checked
                    portfolioCheckboxes.forEach(cb => {
                        if (cb.value !== 'all') cb.checked = false;
                    });
                } else if (this.value !== 'all' && this.checked) {
                    // Uncheck "All" when any individual option is checked
                    allCheckbox.checked = false;
                }

                // If nothing is checked, check "All"
                const anyChecked = Array.from(portfolioCheckboxes).some(cb => cb.checked);
                if (!anyChecked) {
                    allCheckbox.checked = true;
                }

                updatePortfolioDisplay();
                filterProgramsByPortfolio();
            });
            });
        }

        function updatePortfolioDisplay() {
            if (!portfolioText || !portfolioCheckboxes) return;
            const checked = Array.from(portfolioCheckboxes).filter(cb => cb.checked);
            if (checked.length === 0 || (checked.length === 1 && checked[0].value === 'all')) {
                portfolioText.textContent = 'All Portfolios';
            } else {
                const count = checked.length;
                portfolioText.textContent = `${count} Portfolio${count > 1 ? 's' : ''} Selected`;
            }
        }

        function filterProgramsByPortfolio() {
            if (!portfolioCheckboxes || portfolioCheckboxes.length === 0) return;

            const selectedValues = Array.from(portfolioCheckboxes)
                .filter(cb => cb.checked)
                .map(cb => cb.value);

            applyAllFilters(selectedValues, currentStatusFilter, currentMonthFilter);
        }
        } // End if portfolioMultiSelect exists

        // Status filter pills
        document.querySelectorAll('.status-pill').forEach(pill => {
            pill.addEventListener('click', function() {
                // Update active state
                document.querySelectorAll('.status-pill').forEach(p => p.classList.remove('active'));
                this.classList.add('active');

                // Get selected status
                currentStatusFilter = this.dataset.status;

                // Get selected portfolios
                let selectedPortfolios = ['all'];
                if (typeof portfolioCheckboxes !== 'undefined' && portfolioCheckboxes && portfolioCheckboxes.length > 0) {
                    selectedPortfolios = Array.from(portfolioCheckboxes)
                        .filter(cb => cb.checked)
                        .map(cb => cb.value);
                }

                // Apply filters
                applyAllFilters(selectedPortfolios, currentStatusFilter, currentMonthFilter);
            });
        });

        // Month filter pills - add click handlers after pills are rendered
        function attachMonthFilterHandlers() {
            document.querySelectorAll('.release-pill').forEach(pill => {
                pill.addEventListener('click', function() {
                    // Update active state
                    document.querySelectorAll('.release-pill').forEach(p => p.classList.remove('active'));
                    this.classList.add('active');

                    // Get selected month
                    currentMonthFilter = this.dataset.month || 'all';

                    // Get selected portfolios
                    let selectedPortfolios = ['all'];
                    if (typeof portfolioCheckboxes !== 'undefined' && portfolioCheckboxes && portfolioCheckboxes.length > 0) {
                        selectedPortfolios = Array.from(portfolioCheckboxes)
                            .filter(cb => cb.checked)
                            .map(cb => cb.value);
                    }

                    // Apply filters
                    applyAllFilters(selectedPortfolios, currentStatusFilter, currentMonthFilter);
                });
            });
        }

        function updateStatsCards() {
            // Get visible programs based on table rows
            const allRows = document.querySelectorAll('.programs-table tbody tr');

            const visibleProgramNames = [];
            allRows.forEach(row => {
                // Empty display style or undefined means visible
                if (!row.style.display || row.style.display === '' || row.style.display !== 'none') {
                    visibleProgramNames.push(row.dataset.program);
                }
            });

            // Filter programs data to only visible ones
            const visiblePrograms = allProgramsData.filter(p => visibleProgramNames.includes(p.name));

            // Calculate stats
            let projectStats = { on_track: 0, not_started: 0, watch: 0, blocked: 0, total: 0 };
            let epicStats = { on_track: 0, not_started: 0, watch: 0, blocked: 0, total: 0 };

            visiblePrograms.forEach(program => {
                const projects = program.projects || [];

                projects.forEach(project => {
                    projectStats.total++;

                    const epics = project.epics || [];

                    // Determine project health from epic healths
                    if (epics.length === 0) {
                        projectStats.not_started++;
                    } else {
                        const healths = epics.map(e => (e.health || '').toLowerCase());
                        if (healths.some(h => h.includes('blocked'))) {
                            projectStats.blocked++;
                        } else if (healths.some(h => h.includes('watch'))) {
                            projectStats.watch++;
                        } else if (healths.some(h => h.includes('not started'))) {
                            projectStats.not_started++;
                        } else if (healths.some(h => h.includes('on track'))) {
                            projectStats.on_track++;
                        } else {
                            projectStats.not_started++;
                        }
                    }

                    // Count epics
                    epics.forEach(epic => {
                        epicStats.total++;
                        const h = (epic.health || '').toLowerCase();
                        if (h.includes('on track')) {
                            epicStats.on_track++;
                        } else if (h.includes('watch')) {
                            epicStats.watch++;
                        } else if (h.includes('blocked')) {
                            epicStats.blocked++;
                        } else if (h.includes('not started')) {
                            epicStats.not_started++;
                        }
                    });
                });
            });

            // Update Projects card
            document.getElementById('projectsTotal').textContent = projectStats.total;
            document.getElementById('projectsOnTrackCount').textContent = projectStats.on_track;
            document.getElementById('projectsNotStartedCount').textContent = projectStats.not_started;
            document.getElementById('projectsWatchCount').textContent = projectStats.watch;
            document.getElementById('projectsBlockedCount').textContent = projectStats.blocked;

            const projectPctOnTrack = projectStats.total > 0 ? Math.round(projectStats.on_track / projectStats.total * 100) : 0;
            const projectPctNotStarted = projectStats.total > 0 ? Math.round(projectStats.not_started / projectStats.total * 100) : 0;
            const projectPctWatch = projectStats.total > 0 ? Math.round(projectStats.watch / projectStats.total * 100) : 0;
            const projectPctBlocked = projectStats.total > 0 ? Math.round(projectStats.blocked / projectStats.total * 100) : 0;

            document.getElementById('projectsOnTrackPct').textContent = projectPctOnTrack + '%';
            document.getElementById('projectsNotStartedPct').textContent = projectPctNotStarted + '%';
            document.getElementById('projectsWatchPct').textContent = projectPctWatch + '%';
            document.getElementById('projectsBlockedPct').textContent = projectPctBlocked + '%';

            document.getElementById('projectsOnTrackBar').style.width = projectPctOnTrack + '%';
            document.getElementById('projectsNotStartedBar').style.width = projectPctNotStarted + '%';
            document.getElementById('projectsWatchBar').style.width = projectPctWatch + '%';
            document.getElementById('projectsBlockedBar').style.width = projectPctBlocked + '%';

            // Update Epics card
            document.getElementById('epicsTotal').textContent = epicStats.total;
            document.getElementById('epicsOnTrackCount').textContent = epicStats.on_track;
            document.getElementById('epicsNotStartedCount').textContent = epicStats.not_started;
            document.getElementById('epicsWatchCount').textContent = epicStats.watch;
            document.getElementById('epicsBlockedCount').textContent = epicStats.blocked;

            const epicPctOnTrack = epicStats.total > 0 ? Math.round(epicStats.on_track / epicStats.total * 100) : 0;
            const epicPctNotStarted = epicStats.total > 0 ? Math.round(epicStats.not_started / epicStats.total * 100) : 0;
            const epicPctWatch = epicStats.total > 0 ? Math.round(epicStats.watch / epicStats.total * 100) : 0;
            const epicPctBlocked = epicStats.total > 0 ? Math.round(epicStats.blocked / epicStats.total * 100) : 0;

            document.getElementById('epicsOnTrackPct').textContent = epicPctOnTrack + '%';
            document.getElementById('epicsNotStartedPct').textContent = epicPctNotStarted + '%';
            document.getElementById('epicsWatchPct').textContent = epicPctWatch + '%';
            document.getElementById('epicsBlockedPct').textContent = epicPctBlocked + '%';

            document.getElementById('epicsOnTrackBar').style.width = epicPctOnTrack + '%';
            document.getElementById('epicsNotStartedBar').style.width = epicPctNotStarted + '%';
            document.getElementById('epicsWatchBar').style.width = epicPctWatch + '%';
            document.getElementById('epicsBlockedBar').style.width = epicPctBlocked + '%';
        }

        // Monthly release filter
        document.querySelectorAll('.release-pill').forEach(pill => {
            pill.addEventListener('click', function() {
                document.querySelectorAll('.release-pill').forEach(p => p.classList.remove('active'));
                this.classList.add('active');

                const month = this.dataset.month;
                if (month === 'all') {
                    document.querySelectorAll('.program-section').forEach(section => {
                        section.style.display = 'block';
                    });
                } else {
                    document.querySelectorAll('.program-section').forEach(section => {
                        const hasEpicsInMonth = Array.from(section.querySelectorAll('[data-end-date]'))
                            .some(row => row.dataset.endDate && row.dataset.endDate.includes(month));
                        section.style.display = hasEpicsInMonth ? 'block' : 'none';
                    });
                }
            });
        });

        // Program dropdown filter
        const programSelect = document.getElementById('programSelect');
        if (programSelect) {
            programSelect.addEventListener('change', function() {
                const selectedProgram = this.value;
                document.querySelectorAll('.program-section').forEach(section => {
                    if (!selectedProgram || section.dataset.program === selectedProgram) {
                        section.style.display = 'block';
                    } else {
                        section.style.display = 'none';
                    }
                });
            });
        }

        // Search box filter
        const searchBox = document.getElementById('searchBox');
        if (searchBox) {
            searchBox.addEventListener('input', function() {
                const searchTerm = this.value.toLowerCase();
                document.querySelectorAll('.program-section').forEach(section => {
                    const programName = section.dataset.program.toLowerCase();
                    const epicNames = Array.from(section.querySelectorAll('.epic-link'))
                        .map(link => link.textContent.toLowerCase());
                    const hasMatch = programName.includes(searchTerm) || epicNames.some(name => name.includes(searchTerm));
                    section.style.display = hasMatch || searchTerm === '' ? 'block' : 'none';
                });
            });
        }

        // Initialize stats on page load
        updateStatsCards();

        // Table sorting
        let currentSortColumn = null;
        let currentSortDirection = 'asc';

        document.querySelectorAll('.programs-table th[data-column]').forEach(th => {
            th.addEventListener('click', function() {
                const column = this.dataset.column;
                const tbody = document.querySelector('.programs-table tbody');
                const rows = Array.from(tbody.querySelectorAll('tr'));

                // Toggle sort direction
                if (currentSortColumn === column) {
                    currentSortDirection = currentSortDirection === 'asc' ? 'desc' : 'asc';
                } else {
                    currentSortDirection = 'asc';
                    currentSortColumn = column;
                }

                // Update arrow indicators
                document.querySelectorAll('.sort-arrow').forEach(arrow => {
                    arrow.className = 'sort-arrow';
                });
                this.querySelector('.sort-arrow').className = `sort-arrow ${currentSortDirection}`;

                // Sort rows
                rows.sort((a, b) => {
                    let aVal, bVal;

                    switch(column) {
                        case 'portfolio':
                            aVal = a.querySelector('.portfolio-pill')?.textContent || '';
                            bVal = b.querySelector('.portfolio-pill')?.textContent || '';
                            break;
                        case 'program':
                            aVal = a.querySelector('.program-pill')?.textContent || '';
                            bVal = b.querySelector('.program-pill')?.textContent || '';
                            break;
                        case 'health':
                            const healthOrder = {'On Track': 1, 'Watch': 2, 'Blocked': 3, 'Not Started': 4, 'Unknown': 5};
                            aVal = healthOrder[a.querySelector('.health-badge span:last-child')?.textContent] || 999;
                            bVal = healthOrder[b.querySelector('.health-badge span:last-child')?.textContent] || 999;
                            break;
                        case 'comments':
                            aVal = a.querySelector('.comments-cell')?.textContent || '';
                            bVal = b.querySelector('.comments-cell')?.textContent || '';
                            break;
                        case 'manager':
                            aVal = a.querySelector('.manager-cell')?.textContent || '';
                            bVal = b.querySelector('.manager-cell')?.textContent || '';
                            break;
                        case 'updated':
                            aVal = a.querySelector('.updated-cell')?.textContent || '';
                            bVal = b.querySelector('.updated-cell')?.textContent || '';
                            break;
                    }

                    if (column === 'health') {
                        return currentSortDirection === 'asc' ? aVal - bVal : bVal - aVal;
                    } else {
                        if (aVal < bVal) return currentSortDirection === 'asc' ? -1 : 1;
                        if (aVal > bVal) return currentSortDirection === 'asc' ? 1 : -1;
                        return 0;
                    }
                });

                // Re-append sorted rows
                rows.forEach(row => tbody.appendChild(row));
            });
        });

        }); // End DOMContentLoaded

        // Refresh data function
        function refreshData() {
            const btn = document.querySelector('.refresh-btn');
            btn.classList.add('loading');
            btn.disabled = true;

            fetch('/api/refresh-execution-data', { method: 'POST' })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        window.location.reload();
                    } else {
                        alert('Failed to refresh data: ' + data.error);
                        btn.classList.remove('loading');
                        btn.disabled = false;
                    }
                })
                .catch(error => {
                    alert('Error refreshing data: ' + error);
                    btn.classList.remove('loading');
                    btn.disabled = false;
                });
        }

        // Format execution timestamp (Pacific Time)
        const executionTimestamp = document.getElementById('execution-timestamp');
        if (executionTimestamp && executionTimestamp.textContent !== 'Never') {
            const isoDate = executionTimestamp.textContent;
            try {
                const date = new Date(isoDate);
                executionTimestamp.textContent = date.toLocaleString('en-US', {
                    timeZone: 'America/Los_Angeles',
                    month: 'short',
                    day: 'numeric',
                    hour: 'numeric',
                    minute: '2-digit',
                    hour12: true
                }) + ' PT';
            } catch (e) {
                // Keep original text if parsing fails
            }
        }

        // Auto-refresh every 5 minutes
        const REFRESH_INTERVAL = 5 * 60 * 1000; // 5 minutes in milliseconds
        let countdownInterval;
        let remainingSeconds = 300; // 5 minutes

        function updateCountdown() {
            const minutes = Math.floor(remainingSeconds / 60);
            const seconds = remainingSeconds % 60;
            const nextRefreshEl = document.getElementById('next-refresh');

            if (remainingSeconds > 0) {
                nextRefreshEl.textContent = `Next refresh in ${minutes}:${seconds.toString().padStart(2, '0')}`;
                remainingSeconds--;
            } else {
                nextRefreshEl.textContent = 'Refreshing...';
                nextRefreshEl.classList.add('refreshing');
                autoRefreshData();
            }
        }

        function autoRefreshData() {
            fetch('/api/refresh-execution-data', { method: 'POST' })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        window.location.reload();
                    } else {
                        console.error('Auto-refresh failed:', data.error);
                        // Reset countdown and try again
                        remainingSeconds = 300;
                        const nextRefreshEl = document.getElementById('next-refresh');
                        nextRefreshEl.classList.remove('refreshing');
                    }
                })
                .catch(error => {
                    console.error('Auto-refresh error:', error);
                    // Reset countdown and try again
                    remainingSeconds = 300;
                    const nextRefreshEl = document.getElementById('next-refresh');
                    nextRefreshEl.classList.remove('refreshing');
                });
        }

        // Start countdown
        countdownInterval = setInterval(updateCountdown, 1000);
        updateCountdown(); // Initialize immediately
    </script>
    </div> <!-- End main-content -->
</body>
</html>