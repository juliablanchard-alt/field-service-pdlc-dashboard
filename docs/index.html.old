        const allProgramsData = [{"health": "On Track", "health_comments": "Self-Managed\r\nOn Track based on epic health / Project status missing", "id": "a1fEE0000003hTRYAY", "name": "[264] Agentforce Conversation Client (ACC)", "portfolio": "FY27 SC M10 UACP", "program_manager": "Mandy Xiao", "projects": [{"epics": [{"end_date": "2026-05-08", "health": "Not Started", "health_comments": "-", "health_status": "Not Started", "name": "Q4 Testing [264] Phase 1 Migration: Feature Parity on Employee Agents", "number": "-"}, {"end_date": "2026-06-03", "health": "On Track", "health_comments": "5/29: blitz is over. final bug testing.\r\n5/22: feature complete. team is testing.\r\n5/15: refactor stories in code reviews on android and ios.\r\n5/8: ios and Android approaches finalized. Phase-I work started on ios this week and to start next week on Andr...", "health_status": "On Track", "name": "[264.IAM] Unified AEA/ASA Support", "number": "2"}, {"end_date": "2026-06-03", "health": "On Track", "health_comments": "05/29: PRs in review with some feedback. addressing them.\r\n05/22: nishant wrote a doc on updates to ia-message and mohammed elshahawi made updates to config service. work will continue next week into actual work items.\r\n5/15: spike doc ready for ia-messa...", "health_status": "On Track", "name": "[264]ESWP - ACC- Support ACC in API layer", "number": "4"}, {"end_date": "2026-05-23", "health": "Unknown", "health_comments": "05/22: nishant has written an lld and has sent out for review. he will start working starting next week.\r\n5/15: spike done with an agent api. work is ready to be picked up. HLD is signed off.\r\n5/8: HLD review in progress. Investigating core-side api for ...", "health_status": "Canceled", "name": "[264] ESWP - Custom Context Events", "number": "8"}], "name": "[264] Phase 1 Migration: Feature Parity on Employee Agents"}], "subcloud": "FY27 SC M10 UACP", "target_release": "264", "theme": "\u26ab Not Prioritized"}, {"health": "On Track", "healt