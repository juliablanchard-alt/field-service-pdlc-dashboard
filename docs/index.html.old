    <script>
        // Helper function to map release number to freeze month
        function mapReleaseToFreezeMonth(releaseNumber) {
            if (!releaseNumber || !releaseNumber.match(/^\d+$/)) return null;
            const releaseNum = parseInt(releaseNumber);
            const baseRelease = 262;
            const baseYear = 2026;
            const baseMonth = 4;
            const releasesDiff = (releaseNum - baseRelease) / 2;
            const monthsOffset = releasesDiff * 4;
            const totalMonths = baseMonth - 1 + monthsOffset;
            const year = baseYear + Math.floor(totalMonths / 12);
            const month = (totalMonths % 12) + 1;
            return `${year}-${String(month).padStart(2, '0')}`;
        }

        // Store monthly release data for each view
        const monthlyDataByView = {
            program: [{"epic_count": 868, "label": "AUG", "month": "2026-08", "prog_count": 53}],
            project: [{"epic_count": 1, "label": "SEP", "month": "2025-09", "prog_count": 1, "proj_count": 1}, {"epic_count": 2, "label": "DEC", "month": "2025-12", "prog_count": 1, "proj_count": 1}, {"epic_count": 23, "label": "APR", "month": "2026-04", "prog_count": 8, "proj_count": 11}, {"epic_count": 49, "label": "MAY", "month": "2026-05", "prog_count": 13, "proj_count": 31}, {"epic_count": 773, "label": "JUN", "month": "2026-06", "prog_count": 47, "proj_count": 136}],
            epic: [{"epic_count": 1, "label": "SEP", "month": "2025-09", "prog_count": 1}, {"epic_count": 2, "label": "DEC", "month": "2025-12", "prog_count": 1}, {"epic_count": 5, "label": "MAR", "month": "2026-03", "prog_count": 3}, {"epic_count": 199, "label": "APR", "month": "2026-04", "prog_count": 32}, {"epic_count": 209, "label": "MAY", "month": "2026-05", "prog_count": 40}, {"epic_count": 432, "label": "JUN", "month": "2026-06", "prog_count": 47}]
        };

        const monthNames = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];

        // Calculate 7-month range: 1 past, current, 5 future
        function getMonthRange() {
            const now = new Date();
            const months = [];

            // Start from 1 month ago
            for (let i = -1; i <= 5; i++) {
                const date = new Date(now.getFullYear(), now.getMonth() + i, 1);
                const monthNum = String(date.getMonth() + 1).padStart(2, '0');
                const monthLabel = monthNames[date.getMonth()];
                const year = date.getFullYear();
                months.push({
                    monthNum: monthNum,
                    label: monthLabel,
                    yearMonth: `${year}-${monthNum}`
                });
            }
            return months;
        }

        const monthRange = getMonthRange();

        // Render month pills
        function renderMonthPills(view = 'program') {
            const pillsContainer = document.getElementById('releasePills');
            pillsContainer.innerHTML = '';

            // Add ALL filter first
            const allPill = document.createElement('div');
            allPill.className = 'release-pill all-filter active';
            allPill.dataset.month = 'all';
            allPill.textContent = 'ALL';
            pillsContainer.appendChild(allPill);

            // Calculate which months have programs with releases
            const monthsWithReleases = new Set();
            if (typeof allProgramsData !== 'undefined') {
                console.log('Calculating months with releases...');
                allProgramsData.forEach(program => {
                    if (program.target_release) {
                        const freezeMonth = mapReleaseToFreezeMonth(program.target_release);
                        console.log(`Program: ${program.name}, Release: ${program.target_release}, Freeze: ${freezeMonth}`);
                        if (freezeMonth) {
                            monthsWithReleases.add(freezeMonth);
                        }
                    }
                });
                console.log('Months with releases:', Array.from(monthsWithReleases));
            } else {
                console.log('allProgramsData not defined yet');
            }

            // Add month pills for the 7-month range
            monthRange.forEach(month => {
                const pill = document.createElement('div');
                pill.className = 'release-pill';
                pill.dataset.month = month.yearMonth;

                // Add indicator dot if this month has releases
                const hasReleases = monthsWithReleases.has(month.yearMonth);
                pill.innerHTML = hasReleases
                    ? `<span class="month-indicator"></span><span>${month.label}</span>`
                    : `<span>${month.label}</span>`;

                pillsContainer.appendChild(pill);
            });

            // Re-attach click handlers
            attachPillClickHandlers();
        }

        // View toggle functionality
        document.querySelectorAll('.view-toggle').forEach(btn => {
            btn.addEventListener('click', function() {
                // Update active button
                document.querySelectorAll('.view-toggle').forEach(b => b.classList.remove('active'));
                this.classList.add('active');

                const view = this.dataset.view;

                // Show/hide appropriate view
                const programTableView = document.getElementById('programTableView');
                const programsContainer = document.getElementById('programsContainer');

                if (view === 'program') {
                    // Show program table view
                    programTableView.style.display = 'block';
                    programsContainer.style.display = 'none';
                } else {
                    // Show nested projects/epics view
                    programTableView.style.display = 'none';
                    programsContainer.style.display = 'block';
                }

                renderMonthPills(view);
            });
        });

        // Month pill click handlers
        function attachPillClickHandlers() {
            document.querySelectorAll('.release-pill').forEach(pill => {
                pill.addEventListener('click', function() {
                    const month = this.dataset.month;

                    // Remove active from all pills
                    document.querySelectorAll('.release-pill').forEach(p => p.classList.remove('active'));

                    // Add active to clicked pill
                    this.classList.add('active');

                    // Update current month filter
                    currentMonthFilter = month || 'all';

                    // Get selected portfolios
                    let selectedPortfolios = ['all'];
                    if (typeof portfolioCheckboxes !== 'undefined' && portfolioCheckboxes && portfolioCheckboxes.length > 0) {
                        selectedPortfolios = Array.from(portfolioCheckboxes)
                            .filter(cb => cb.checked)
                            .map(cb => cb.value);
                    }

                    // Apply all filters
                    applyAllFilters(selectedPortfolios, currentStatusFilter, currentMonthFilter);
                });
            });
        }

        // Status filter functionality
        document.querySelectorAll('.status-pill').forEach(pill => {
            pill.addEventListener('click', function() {
                document.querySelectorAll('.status-pill').forEach(p => p.classList.remove('active'));
                this.classList.add('active');

                const status = this.dataset.status;
                console.log('Filter by status:', status);
                // Implement status filtering here
            });
        });

        // Initialize on page load
        renderMonthPills('program');
    </script>


