<script>
// View toggle
document.querySelectorAll('.allocations-view-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        const view = btn.dataset.view;

        // Update button states
        document.querySelectorAll('.allocations-view-btn').forEach(b => {
            if (b === btn) {
                b.style.background = '#0176D3';
                b.style.color = 'white';
                b.style.border = 'none';
                b.classList.add('active');
            } else {
                b.style.background = 'white';
                b.style.color = '#475569';
                b.style.border = '1px solid #e5e7eb';
                b.classList.remove('active');
            }
        });

        // Toggle views
        if (view === 'by-team') {
            document.getElementById('by-team-view').style.display = 'block';
            document.getElementById('by-program-view').style.display = 'none';
        } else {
            document.getElementById('by-team-view').style.display = 'none';
            document.getElementById('by-program-view').style.display = 'block';
        }
    });
});

// Team search filter
document.getElementById('team-search').addEventListener('input', (e) => {
    const search = e.target.value.toLowerCase();
    const rows = document.querySelectorAll('#teams-table-body .team-row');
    rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(search) ? '' : 'none';
    });
});

// Program search filter
document.getElementById('program-search').addEventListener('input', (e) => {
    const search = e.target.value.toLowerCase();
    const rows = document.querySelectorAll('.program-capacity-row');

    rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(search) ? '' : 'none';
    });
});
</script>
    </div>

    <script>
        let selectedPortfolios = new Set();

        function togglePortfolioDropdown() {
            const dropdown = document.getElementById('portfolio-dropdown');
            dropdown.classList.toggle('show');
        }

        // Close dropdown when clicking outside
        document.addEventListener('click', (e) => {
            const filter = document.querySelector('.portfolio-filter');
            const dropdown = document.getElementById('portfolio-dropdown');
            if (filter && !filter.contains(e.target)) {
                dropdown.classList.remove('show');
            }
        });

        function togglePortfolioCheckbox(optionElement, event) {
            const checkbox = optionElement.querySelector('input[type="checkbox"]');
            if (event && event.target.tagName !== 'INPUT') {
                checkbox.checked = !checkbox.checked;
            }
            updatePortfolioFilter(event);
        }

        function updatePortfolioFilter(event) {
            if (event) {
                event.stopPropagation();
            }

            // Get all checked portfolios
            selectedPortfolios.clear();
            document.querySelectorAll('.portfolio-dropdown input[type="checkbox"]').forEach(checkbox => {
                const optionDiv = checkbox.closest('.portfolio-option');
                if (checkbox.checked) {
                    selectedPortfolios.add(checkbox.value);
                    optionDiv.classList.add('selected');
                } else {
                    optionDiv.classList.remove('selected');
                }
            });

            // Update button text
            const button = document.getElementById('portfolio-button');
            if (selectedPortfolios.size === 0) {
                button.textContent = 'All Portfolios';
            } else if (selectedPortfolios.size === 1) {
                // Show the full portfolio name
                const portfolioName = Array.from(selectedPortfolios)[0];
                // Truncate if too long
                button.textContent = portfolioName.length > 40 ? portfolioName.substring(0, 37) + '...' : portfolioName;
            } else {
                button.textContent = `${selectedPortfolios.size} Portfolios`;
            }

            // Filter PDLC Overview cards
            const allCards = document.querySelectorAll('.program-card');
            allCards.forEach(card => {
                const cardPortfolio = card.getAttribute('data-portfolio');
                if (selectedPortfolios.size === 0 || selectedPortfolios.has(cardPortfolio)) {
                    card.style.display = '';
                } else {
                    card.style.display = 'none';
                }
            });

            // Filter Execution tree view rows
            const allRows = document.querySelectorAll('#execution-view .program-row');
            allRows.forEach(row => {
                const rowPortfolio = row.getAttribute('data-portfolio');
                if (selectedPortfolios.size === 0 || selectedPortfolios.has(rowPortfolio)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });

            // Filter Allocations tab program rows AND their team sub-rows
            const allocationsRows = document.querySelectorAll('#allocations-view .program-capacity-row');
            allocationsRows.forEach(row => {
                const rowPortfolio = row.getAttribute('data-portfolio');
                const shouldShow = selectedPortfolios.size === 0 || selectedPortfolios.has(rowPortfolio);

                if (shouldShow) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }

                // Hide/show all team sub-rows that follow this program row
                let nextRow = row.nextElementSibling;
                while (nextRow && nextRow.classList.contains('team-sub-row')) {
                    nextRow.style.display = shouldShow ? '' : 'none';
                    nextRow = nextRow.nextElementSibling;
                }
            });

            // Filter Allocations tab team rows (By Team view) AND their program sub-rows
            const teamRows = document.querySelectorAll('#allocations-view .team-row');
            teamRows.forEach(row => {
                const teamPortfolios = (row.getAttribute('data-portfolios') || '').split(',').filter(p => p);
                // Show team if: no filter active OR team works on any of the selected portfolios
                const shouldShow = selectedPortfolios.size === 0 || teamPortfolios.some(p => selectedPortfolios.has(p));

                if (shouldShow) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }

                // Hide/show all program sub-rows that follow this team row
                let nextRow = row.nextElementSibling;
                while (nextRow && nextRow.classList.contains('program-row')) {
                    nextRow.style.display = shouldShow ? '' : 'none';
                    nextRow = nextRow.nextElementSibling;
                }
            });

            // Update phase counts
            updatePhaseCounts();

            // Update Execution stats
            updateExecutionStats();

            // Update Allocations stats
            updateAllocationsStats();

            // Save to localStorage
            localStorage.setItem('selectedPortfolios', JSON.stringify(Array.from(selectedPortfolios)));
        }

        function updatePhaseCounts() {
            // Phase 0 count
            const phase0Cards = document.querySelectorAll('.phase-0 .program-card:not([style*="display: none"])');
            const phase0Count = document.querySelector('.phase-0 .phase-count');
            if (phase0Count) phase0Count.textContent = phase0Cards.length;

            // Phase 1 Prototyping count
            const prototypingCards = document.querySelectorAll('.phase-1 .prototyping-subcolumn .program-card:not([style*="display: none"])');
            const prototypingCount = document.querySelector('.phase-1 .prototyping-subcolumn .subcolumn-count');
            if (prototypingCount) prototypingCount.textContent = prototypingCards.length;

            // Phase 1 Ready for Review count
            const readyCards = document.querySelectorAll('.phase-1 .ready-subcolumn .program-card:not([style*="display: none"])');
            const readyCount = document.querySelector('.phase-1 .ready-subcolumn .subcolumn-count');
            if (readyCount) readyCount.textContent = readyCards.length;

            // Phase 1 total count (Prototyping + Ready for Review)
            const phase1TotalCount = document.querySelector('.phase-1 .phase-count');
            if (phase1TotalCount) phase1TotalCount.textContent = prototypingCards.length + readyCards.length;

            // Phase 2 Ready for BUP count
            const readyBupCards = document.querySelectorAll('.phase-2 .readybup-subcolumn .program-card:not([style*="display: none"])');
            const readyBupCount = document.querySelector('.phase-2 .readybup-subcolumn .subcolumn-count');
            if (readyBupCount) readyBupCount.textContent = readyBupCards.length;

            // Phase 2 In Progress count
            const inProgressCards = document.querySelectorAll('.phase-2 .inprogress-subcolumn .program-card:not([style*="display: none"])');
            const inProgressCount = document.querySelector('.phase-2 .inprogress-subcolumn .subcolumn-count');
            if (inProgressCount) inProgressCount.textContent = inProgressCards.length;

            // Phase 2 total count (Ready for BUP + In Progress)
            const phase2TotalCount = document.querySelector('.phase-2 .phase-count');
            if (phase2TotalCount) phase2TotalCount.textContent = readyBupCards.length + inProgressCards.length;

            // Phase 3 count
            const phase3Cards = document.querySelectorAll('.phase-3 .program-card:not([style*="display: none"])');
            const phase3Count = document.querySelector('.phase-3 .phase-count');
            if (phase3Count) phase3Count.textContent = phase3Cards.length;
        }

        function updateExecutionStats() {
            // Count visible programs/projects/epics in Execution tab
            const visiblePrograms = document.querySelectorAll('#execution-view .program-row:not([style*="display: none"])');

            let progOnTrack = 0, progNotStarted = 0, progWatch = 0, progBlocked = 0, progCompleted = 0;
            let projOnTrack = 0, projNotStarted = 0, projWatch = 0, projBlocked = 0, projCompleted = 0;
            let epicOnTrack = 0, epicNotStarted = 0, epicWatch = 0, epicBlocked = 0, epicCompleted = 0;
            let totalProjects = 0, totalEpics = 0;

            visiblePrograms.forEach(progRow => {
                const progHealth = (progRow.querySelector('.program-badge')?.textContent || '').toLowerCase();
                if (progHealth.includes('track')) progOnTrack++;
                else if (progHealth.includes('not started')) progNotStarted++;
                else if (progHealth.includes('watch') || progHealth.includes('risk')) progWatch++;
                else if (progHealth.includes('blocked')) progBlocked++;
                else if (progHealth.includes('completed')) progCompleted++;

                // Count projects in this program
                progRow.querySelectorAll('.project-row').forEach(projRow => {
                    totalProjects++;
                    const projHealth = (projRow.querySelector('.program-badge')?.textContent || '').toLowerCase();
                    if (projHealth.includes('track')) projOnTrack++;
                    else if (projHealth.includes('not started')) projNotStarted++;
                    else if (projHealth.includes('watch') || projHealth.includes('risk')) projWatch++;
                    else if (projHealth.includes('blocked')) projBlocked++;
                    else if (projHealth.includes('completed')) projCompleted++;

                    // Count epics in this project
                    projRow.querySelectorAll('.epic-card').forEach(epicCard => {
                        totalEpics++;
                        // Get health from class name (e.g., "health-on-track")
                        const epicClasses = epicCard.className;
                        if (epicClasses.includes('health-on-track') || epicClasses.includes('health-green')) epicOnTrack++;
                        else if (epicClasses.includes('health-not-started') || epicClasses.includes('health-gray')) epicNotStarted++;
                        else if (epicClasses.includes('health-watch') || epicClasses.includes('health-yellow') || epicClasses.includes('health-at-risk')) epicWatch++;
                        else if (epicClasses.includes('health-blocked') || epicClasses.includes('health-red')) epicBlocked++;
                        else if (epicClasses.includes('health-completed') || epicClasses.includes('health-blue')) epicCompleted++;
                    });
                });
            });

            // Update Programs card
            const progTotal = document.querySelector('#execution-view .stat-card:nth-child(1) .stat-value');
            if (progTotal) progTotal.textContent = visiblePrograms.length;

            const progNotStartedCount = document.querySelector('#execution-view .stat-card:nth-child(1) .stat-row:nth-child(1) .stat-count');
            const progOnTrackCount = document.querySelector('#execution-view .stat-card:nth-child(1) .stat-row:nth-child(2) .stat-count');
            const progWatchCount = document.querySelector('#execution-view .stat-card:nth-child(1) .stat-row:nth-child(3) .stat-count');
            const progBlockedCount = document.querySelector('#execution-view .stat-card:nth-child(1) .stat-row:nth-child(4) .stat-count');
            const progCompletedCount = document.querySelector('#execution-view .stat-card:nth-child(1) .stat-row:nth-child(5) .stat-count');

            if (progNotStartedCount) progNotStartedCount.textContent = progNotStarted;
            if (progOnTrackCount) progOnTrackCount.textContent = progOnTrack;
            if (progWatchCount) progWatchCount.textContent = progWatch;
            if (progBlockedCount) progBlockedCount.textContent = progBlocked;
            if (progCompletedCount) progCompletedCount.textContent = progCompleted;

            // Update percentages and bars
            const totalProg = visiblePrograms.length;
            if (totalProg > 0) {
                document.querySelector('#execution-view .stat-card:nth-child(1) .stat-row:nth-child(1) .stat-percent').textContent = Math.round(progNotStarted / totalProg * 100) + '%';
                document.querySelector('#execution-view .stat-card:nth-child(1) .stat-row:nth-child(1) .stat-bar-fill').style.width = Math.round(progNotStarted / totalProg * 100) + '%';

                document.querySelector('#execution-view .stat-card:nth-child(1) .stat-row:nth-child(2) .stat-percent').textContent = Math.round(progOnTrack / totalProg * 100) + '%';
                document.querySelector('#execution-view .stat-card:nth-child(1) .stat-row:nth-child(2) .stat-bar-fill').style.width = Math.round(progOnTrack / totalProg * 100) + '%';

                document.querySelector('#execution-view .stat-card:nth-child(1) .stat-row:nth-child(3) .stat-percent').textContent = Math.round(progWatch / totalProg * 100) + '%';
                document.querySelector('#execution-view .stat-card:nth-child(1) .stat-row:nth-child(3) .stat-bar-fill').style.width = Math.round(progWatch / totalProg * 100) + '%';

                document.querySelector('#execution-view .stat-card:nth-child(1) .stat-row:nth-child(4) .stat-percent').textContent = Math.round(progBlocked / totalProg * 100) + '%';
                document.querySelector('#execution-view .stat-card:nth-child(1) .stat-row:nth-child(4) .stat-bar-fill').style.width = Math.round(progBlocked / totalProg * 100) + '%';

                document.querySelector('#execution-view .stat-card:nth-child(1) .stat-row:nth-child(5) .stat-percent').textContent = Math.round(progCompleted / totalProg * 100) + '%';
                document.querySelector('#execution-view .stat-card:nth-child(1) .stat-row:nth-child(5) .stat-bar-fill').style.width = Math.round(progCompleted / totalProg * 100) + '%';
            }

            // Update Projects card
            const projTotal = document.querySelector('#execution-view .stat-card:nth-child(2) .stat-value');
            if (projTotal) projTotal.textContent = totalProjects;

            const projNotStartedCount = document.querySelector('#execution-view .stat-card:nth-child(2) .stat-row:nth-child(1) .stat-count');
            const projOnTrackCount = document.querySelector('#execution-view .stat-card:nth-child(2) .stat-row:nth-child(2) .stat-count');
            const projWatchCount = document.querySelector('#execution-view .stat-card:nth-child(2) .stat-row:nth-child(3) .stat-count');
            const projBlockedCount = document.querySelector('#execution-view .stat-card:nth-child(2) .stat-row:nth-child(4) .stat-count');
            const projCompletedCount = document.querySelector('#execution-view .stat-card:nth-child(2) .stat-row:nth-child(5) .stat-count');

            if (projNotStartedCount) projNotStartedCount.textContent = projNotStarted;
            if (projOnTrackCount) projOnTrackCount.textContent = projOnTrack;
            if (projWatchCount) projWatchCount.textContent = projWatch;
            if (projBlockedCount) projBlockedCount.textContent = projBlocked;
            if (projCompletedCount) projCompletedCount.textContent = projCompleted;

            if (totalProjects > 0) {
                document.querySelector('#execution-view .stat-card:nth-child(2) .stat-row:nth-child(1) .stat-percent').textContent = Math.round(projNotStarted / totalProjects * 100) + '%';
                document.querySelector('#execution-view .stat-card:nth-child(2) .stat-row:nth-child(1) .stat-bar-fill').style.width = Math.round(projNotStarted / totalProjects * 100) + '%';

                document.querySelector('#execution-view .stat-card:nth-child(2) .stat-row:nth-child(2) .stat-percent').textContent = Math.round(projOnTrack / totalProjects * 100) + '%';
                document.querySelector('#execution-view .stat-card:nth-child(2) .stat-row:nth-child(2) .stat-bar-fill').style.width = Math.round(projOnTrack / totalProjects * 100) + '%';

                document.querySelector('#execution-view .stat-card:nth-child(2) .stat-row:nth-child(3) .stat-percent').textContent = Math.round(projWatch / totalProjects * 100) + '%';
                document.querySelector('#execution-view .stat-card:nth-child(2) .stat-row:nth-child(3) .stat-bar-fill').style.width = Math.round(projWatch / totalProjects * 100) + '%';

                document.querySelector('#execution-view .stat-card:nth-child(2) .stat-row:nth-child(4) .stat-percent').textContent = Math.round(projBlocked / totalProjects * 100) + '%';
                document.querySelector('#execution-view .stat-card:nth-child(2) .stat-row:nth-child(4) .stat-bar-fill').style.width = Math.round(projBlocked / totalProjects * 100) + '%';

                document.querySelector('#execution-view .stat-card:nth-child(2) .stat-row:nth-child(5) .stat-percent').textContent = Math.round(projCompleted / totalProjects * 100) + '%';
                document.querySelector('#execution-view .stat-card:nth-child(2) .stat-row:nth-child(5) .stat-bar-fill').style.width = Math.round(projCompleted / totalProjects * 100) + '%';
            }

            // Update Epics card
            const epicTotal = document.querySelector('#execution-view .stat-card:nth-child(3) .stat-value');
            if (epicTotal) epicTotal.textContent = totalEpics;

            const epicNotStartedCount = document.querySelector('#execution-view .stat-card:nth-child(3) .stat-row:nth-child(1) .stat-count');
            const epicOnTrackCount = document.querySelector('#execution-view .stat-card:nth-child(3) .stat-row:nth-child(2) .stat-count');
            const epicWatchCount = document.querySelector('#execution-view .stat-card:nth-child(3) .stat-row:nth-child(3) .stat-count');
            const epicBlockedCount = document.querySelector('#execution-view .stat-card:nth-child(3) .stat-row:nth-child(4) .stat-count');
            const epicCompletedCount = document.querySelector('#execution-view .stat-card:nth-child(3) .stat-row:nth-child(5) .stat-count');

            if (epicNotStartedCount) epicNotStartedCount.textContent = epicNotStarted;
            if (epicOnTrackCount) epicOnTrackCount.textContent = epicOnTrack;
            if (epicWatchCount) epicWatchCount.textContent = epicWatch;
            if (epicBlockedCount) epicBlockedCount.textContent = epicBlocked;
            if (epicCompletedCount) epicCompletedCount.textContent = epicCompleted;

            if (totalEpics > 0) {
                document.querySelector('#execution-view .stat-card:nth-child(3) .stat-row:nth-child(1) .stat-percent').textContent = Math.round(epicNotStarted / totalEpics * 100) + '%';
                document.querySelector('#execution-view .stat-card:nth-child(3) .stat-row:nth-child(1) .stat-bar-fill').style.width = Math.round(epicNotStarted / totalEpics * 100) + '%';

                document.querySelector('#execution-view .stat-card:nth-child(3) .stat-row:nth-child(2) .stat-percent').textContent = Math.round(epicOnTrack / totalEpics * 100) + '%';
                document.querySelector('#execution-view .stat-card:nth-child(3) .stat-row:nth-child(2) .stat-bar-fill').style.width = Math.round(epicOnTrack / totalEpics * 100) + '%';

                document.querySelector('#execution-view .stat-card:nth-child(3) .stat-row:nth-child(3) .stat-percent').textContent = Math.round(epicWatch / totalEpics * 100) + '%';
                document.querySelector('#execution-view .stat-card:nth-child(3) .stat-row:nth-child(3) .stat-bar-fill').style.width = Math.round(epicWatch / totalEpics * 100) + '%';

                document.querySelector('#execution-view .stat-card:nth-child(3) .stat-row:nth-child(4) .stat-percent').textContent = Math.round(epicBlocked / totalEpics * 100) + '%';
                document.querySelector('#execution-view .stat-card:nth-child(3) .stat-row:nth-child(4) .stat-bar-fill').style.width = Math.round(epicBlocked / totalEpics * 100) + '%';

                document.querySelector('#execution-view .stat-card:nth-child(3) .stat-row:nth-child(5) .stat-percent').textContent = Math.round(epicCompleted / totalEpics * 100) + '%';
                document.querySelector('#execution-view .stat-card:nth-child(3) .stat-row:nth-child(5) .stat-bar-fill').style.width = Math.round(epicCompleted / totalEpics * 100) + '%';
            }
        }

        function updateAllocationsStats() {
            // Count visible team rows and sum their headcount
            const visibleTeamRows = document.querySelectorAll('#allocations-view .team-row:not([style*="display: none"])');

            let totalFilledVisible = 0;
            let totalNonFilledVisible = 0;

            visibleTeamRows.forEach(row => {
                const filled = parseInt(row.getAttribute('data-filled') || '0');
                const nonFilled = parseInt(row.getAttribute('data-non-filled') || '0');
                totalFilledVisible += filled;
                totalNonFilledVisible += nonFilled;
            });

            // Update stats cards
            const teamsCount = document.querySelector('#allocations-view .stat-card:nth-child(1) .stat-value');
            if (teamsCount) teamsCount.textContent = visibleTeamRows.length;

            const filledCount = document.querySelector('#allocations-view .stat-card:nth-child(2) .stat-value');
            if (filledCount) filledCount.textContent = totalFilledVisible;

            const openCount = document.querySelector('#allocations-view .stat-card:nth-child(3) .stat-value');
            if (openCount) openCount.textContent = totalNonFilledVisible;
        }

        function selectAllPortfolios() {
            // Check all checkboxes
            document.querySelectorAll('.portfolio-dropdown input[type="checkbox"]').forEach(checkbox => {
                checkbox.checked = true;
            });
            updatePortfolioFilter();
        }

        function clearPortfolioFilter() {
            // Uncheck all checkboxes
            document.querySelectorAll('.portfolio-dropdown input[type="checkbox"]').forEach(checkbox => {
                checkbox.checked = false;
            });
            updatePortfolioFilter();
        }

        // Restore filter on page load
        document.addEventListener('DOMContentLoaded', () => {
            const savedPortfolios = localStorage.getItem('selectedPortfolios');
            if (savedPortfolios) {
                const portfolios = JSON.parse(savedPortfolios);
                portfolios.forEach(portfolio => {
                    const checkbox = document.querySelector(`input[value="${portfolio}"]`);
                    if (checkbox) {
                        checkbox.checked = true;
                        checkbox.closest('.portfolio-option').classList.add('selected');
                    }
                });
                updatePortfolioFilter();
            }

            // Update last updated timestamp
            const lastUpdated = "2026-07-12T09:42:40";
            document.querySelector('header .last-updated').textContent = `Last updated: ${lastUpdated}`;
        });

        function toggleProgram(programId) {
            const content = document.getElementById('program-' + programId);
            const icon = document.getElementById('expand-' + programId);
            if (content.style.display === 'none') {
                content.style.display = 'block';
                icon.classList.add('expanded');
            } else {
                content.style.display = 'none';
                icon.classList.remove('expanded');
            }
        }

        function toggleProject(projectId) {
            const content = document.getElementById('project-' + projectId);
            const icon = document.getElementById('expand-' + projectId);
            if (content.style.display === 'none') {
                content.style.display = 'block';
                icon.classList.add('expanded');
            } else {
                content.style.display = 'none';
                icon.classList.remove('expanded');
            }
        }

        function switchExecutionView(viewName) {
            // Hide all execution subviews
            document.querySelectorAll('.execution-subview').forEach(view => {
                view.classList.remove('active');
            });

            // Deactivate all execution tabs
            document.querySelectorAll('.execution-tab').forEach(tab => {
                tab.classList.remove('active');
            });

            // Show selected execution subview
            const selectedView = document.getElementById(`execution-${viewName}-view`);
            if (selectedView) {
                selectedView.classList.add('active');
            }

            // Activate selected tab
            event.target.classList.add('active');
        }

        // Epic expand/collapse
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.epic-expand-btn').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    const item = this.closest('.epic-list-item');
                    const details = item.querySelector('.epic-list-details');
                    if (details.style.display === 'none' || !details.style.display) {
                        details.style.display = 'grid';
                        this.classList.add('expanded');
                    } else {
                        details.style.display = 'none';
                        this.classList.remove('expanded');
                    }
                });
            });

            // INITIALIZE: Programs view is active by default, keep everything collapsed on page load
            // (No expansion needed - Programs view shows collapsed programs)

            // View toggles
            document.querySelectorAll('.view-toggle').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('.view-toggle').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');

                    const selectedView = this.dataset.view;

                    if (selectedView === 'program') {
                        // PROGRAMS VIEW: Collapse all, show only program rows
                        document.querySelectorAll('#execution-view .program-row').forEach(row => {
                            row.classList.remove('expanded');
                            const header = row.querySelector('.program-header');
                            if (header) header.classList.remove('expanded');
                        });
                        document.querySelectorAll('#execution-view .project-row').forEach(row => {
                            row.classList.remove('expanded');
                            const header = row.querySelector('.project-header');
                            if (header) header.classList.remove('expanded');
                        });

                    } else if (selectedView === 'project') {
                        // PROJECTS VIEW: Expand programs, collapse projects
                        document.querySelectorAll('#execution-view .program-row').forEach(row => {
                            row.classList.add('expanded');
                            const header = row.querySelector('.program-header');
                            if (header) header.classList.add('expanded');
                        });
                        document.querySelectorAll('#execution-view .project-row').forEach(row => {
                            row.classList.remove('expanded');
                            const header = row.querySelector('.project-header');
                            if (header) header.classList.remove('expanded');
                        });

                    } else if (selectedView === 'epic') {
                        // EPICS VIEW: Expand everything
                        document.querySelectorAll('#execution-view .program-row').forEach(row => {
                            row.classList.add('expanded');
                            const header = row.querySelector('.program-header');
                            if (header) header.classList.add('expanded');
                        });
                        document.querySelectorAll('#execution-view .project-row').forEach(row => {
                            row.classList.add('expanded');
                            const header = row.querySelector('.project-header');
                            if (header) header.classList.add('expanded');
                        });
                    } else if (selectedView === 'by-program') {
                        // ALLOCATIONS: Show Programs view, hide Teams view
                        const programView = document.getElementById('by-program-view');
                        const teamView = document.getElementById('by-team-view');
                        if (programView) programView.style.display = '';
                        if (teamView) teamView.style.display = 'none';
                    } else if (selectedView === 'by-team') {
                        // ALLOCATIONS: Show Teams view, hide Programs view
                        const programView = document.getElementById('by-program-view');
                        const teamView = document.getElementById('by-team-view');
                        if (programView) programView.style.display = 'none';
                        if (teamView) teamView.style.display = '';
                    }

                    // RE-APPLY STATUS FILTER after view changes (only for execution tab)
                    if (selectedView !== 'by-program' && selectedView !== 'by-team') {
                        const activeStatusPill = document.querySelector('.filter-pill[data-status].active');
                        if (activeStatusPill) {
                            activeStatusPill.click();
                        }
                    }
                });
            });

            // Status filter pills
            document.querySelectorAll('.filter-pill[data-status]').forEach(pill => {
                pill.addEventListener('click', function() {
                    document.querySelectorAll('.filter-pill[data-status]').forEach(p => p.classList.remove('active'));
                    this.classList.add('active');

                    const selectedStatus = this.getAttribute('data-status');

                    // Check which view is active
                    const activeView = document.querySelector('.view-toggle.active');
                    const viewType = activeView ? activeView.dataset.view : 'epic';

                    if (selectedStatus === 'all') {
                        // Show everything (BUT RESPECT PORTFOLIO FILTER)
                        document.querySelectorAll('#execution-view .program-row').forEach(p => {
                            const portfolio = p.getAttribute('data-portfolio');
                            const matchesPortfolio = selectedPortfolios.size === 0 || selectedPortfolios.has(portfolio);
                            p.style.display = matchesPortfolio ? '' : 'none';
                        });
                        document.querySelectorAll('#execution-view .project-row').forEach(p => p.style.display = '');
                        document.querySelectorAll('.epic-card').forEach(e => e.style.display = '');
                    } else {
                        // VIEW-DEPENDENT STATUS FILTERING

                        if (viewType === 'program') {
                            // PROGRAMS VIEW: Filter ONLY by program health
                            document.querySelectorAll('#execution-view .program-row').forEach(program => {
                                const badge = program.querySelector('.program-badge');
                                const matchesStatus = badge && badge.classList.contains('badge-' + selectedStatus);
                                const portfolio = program.getAttribute('data-portfolio');
                                const matchesPortfolio = selectedPortfolios.size === 0 || selectedPortfolios.has(portfolio);

                                program.style.display = (matchesStatus && matchesPortfolio) ? '' : 'none';
                            });

                            // Hide all projects/epics (Programs view shows programs only)
                            document.querySelectorAll('#execution-view .project-row').forEach(p => p.style.display = 'none');

                        } else if (viewType === 'project') {
                            // PROJECTS VIEW: Filter ONLY by project health
                            const matchingProjects = new Set();
                            document.querySelectorAll('#execution-view .project-row').forEach(project => {
                                const projectHealth = project.dataset.projectHealth;
                                if (projectHealth === selectedStatus) {
                                    matchingProjects.add(project);
                                }
                            });

                            // Show programs that contain matching projects
                            const programsWithMatchingProjects = new Set();
                            matchingProjects.forEach(project => {
                                const program = project.closest('.program-row');
                                if (program) programsWithMatchingProjects.add(program);
                            });

                            document.querySelectorAll('#execution-view .program-row').forEach(program => {
                                const hasMatchingProjects = programsWithMatchingProjects.has(program);
                                const portfolio = program.getAttribute('data-portfolio');
                                const matchesPortfolio = selectedPortfolios.size === 0 || selectedPortfolios.has(portfolio);

                                program.style.display = (hasMatchingProjects && matchesPortfolio) ? '' : 'none';
                            });

                            document.querySelectorAll('#execution-view .project-row').forEach(project => {
                                const matchesStatus = matchingProjects.has(project);
                                const program = project.closest('.program-row');
                                const portfolio = program ? program.getAttribute('data-portfolio') : null;
                                const matchesPortfolio = selectedPortfolios.size === 0 || selectedPortfolios.has(portfolio);

                                project.style.display = (matchesStatus && matchesPortfolio) ? '' : 'none';
                            });

                        } else {
                            // EPICS VIEW: Filter ONLY by epic health

                            // FIRST: Expand all programs and projects (Epics view requirement)
                            document.querySelectorAll('#execution-view .program-row').forEach(row => {
                                row.classList.add('expanded');
                                const header = row.querySelector('.program-header');
                                if (header) header.classList.add('expanded');
                            });
                            document.querySelectorAll('#execution-view .project-row').forEach(row => {
                                row.classList.add('expanded');
                                const header = row.querySelector('.project-header');
                                if (header) header.classList.add('expanded');
                            });

                            const matchingEpics = [];
                            const searchClass = 'health-' + selectedStatus;
                            console.log('Epics view: searching for class:', searchClass);

                            document.querySelectorAll('.epic-card').forEach(epic => {
                                const epicClasses = epic.className;
                                if (epicClasses.includes(searchClass)) {
                                    matchingEpics.push(epic);
                                }
                            });

                            console.log('Epics view: found', matchingEpics.length, 'matching epics');

                            // If 0 epics match, hide EVERYTHING and show empty state
                            if (matchingEpics.length === 0) {
                                console.log('Epics view: 0 matches - hiding all programs/projects/epics');
                                document.querySelectorAll('#execution-view .program-row').forEach(p => p.style.display = 'none');
                                document.querySelectorAll('#execution-view .project-row').forEach(p => p.style.display = 'none');
                                document.querySelectorAll('.epic-card').forEach(e => e.style.display = 'none');

                                // Show empty state
                                const emptyState = document.getElementById('empty-state');
                                const treeContainer = document.getElementById('tree-container');
                                if (emptyState) emptyState.style.display = 'block';
                                if (treeContainer) treeContainer.style.display = 'none';
                            } else {
                                // Hide empty state, show tree
                                const emptyState = document.getElementById('empty-state');
                                const treeContainer = document.getElementById('tree-container');
                                if (emptyState) emptyState.style.display = 'none';
                                if (treeContainer) treeContainer.style.display = 'block';

                                // Bubble up to show parent projects/programs
                                const matchingProjects = new Set();
                                matchingEpics.forEach(epic => {
                                    const project = epic.closest('.project-row');
                                    if (project) matchingProjects.add(project);
                                });

                                const matchingPrograms = new Set();
                                matchingProjects.forEach(project => {
                                    const program = project.closest('.program-row');
                                    if (program) matchingPrograms.add(program);
                                });

                                document.querySelectorAll('#execution-view .program-row').forEach(program => {
                                    const hasMatchingEpics = matchingPrograms.has(program);
                                    const portfolio = program.getAttribute('data-portfolio');
                                    const matchesPortfolio = selectedPortfolios.size === 0 || selectedPortfolios.has(portfolio);

                                    program.style.display = (hasMatchingEpics && matchesPortfolio) ? '' : 'none';
                                });

                                document.querySelectorAll('#execution-view .project-row').forEach(project => {
                                    const hasMatchingEpics = matchingProjects.has(project);
                                    const program = project.closest('.program-row');
                                    const portfolio = program ? program.getAttribute('data-portfolio') : null;
                                    const matchesPortfolio = selectedPortfolios.size === 0 || selectedPortfolios.has(portfolio);

                                    project.style.display = (hasMatchingEpics && matchesPortfolio) ? '' : 'none';
                                });

                                document.querySelectorAll('.epic-card').forEach(epic => {
                                    const matchesStatus = matchingEpics.includes(epic);
                                    const program = epic.closest('.program-row');
                                    const portfolio = program ? program.getAttribute('data-portfolio') : null;
                                    const matchesPortfolio = selectedPortfolios.size === 0 || selectedPortfolios.has(portfolio);

                                    epic.style.display = (matchesStatus && matchesPortfolio) ? '' : 'none';
                                });
                            }
                        }
                    }
                });
            });

            // Month filter pills
            document.querySelectorAll('.month-pill').forEach(pill => {
                pill.addEventListener('click', function() {
                    document.querySelectorAll('.month-pill').forEach(p => p.classList.remove('active'));
                    this.classList.add('active');

                    const selectedMonth = this.dataset.month;

                    if (selectedMonth === 'all') {
                        // Show all programs, projects, month columns (BUT RESPECT PORTFOLIO FILTER)
                        document.querySelectorAll('#execution-view .program-row').forEach(p => {
                            const portfolio = p.getAttribute('data-portfolio');
                            const matchesPortfolio = selectedPortfolios.size === 0 || selectedPortfolios.has(portfolio);
                            p.style.display = matchesPortfolio ? '' : 'none';
                        });
                        document.querySelectorAll('#execution-view .project-row').forEach(p => p.style.display = '');
                        document.querySelectorAll('.month-column').forEach(c => c.style.display = '');
                    } else {
                        // AUTO-SWITCH TO EPIC VIEW
                        document.querySelectorAll('.view-toggle').forEach(t => t.classList.remove('active'));
                        document.querySelector('.view-toggle[data-view="epic"]').classList.add('active');

                        // AUTO-EXPAND ALL PROGRAMS AND PROJECTS
                        document.querySelectorAll('#execution-view .program-row').forEach(row => {
                            row.classList.add('expanded');
                            const header = row.querySelector('.program-header');
                            if (header) header.classList.add('expanded');
                        });

                        document.querySelectorAll('#execution-view .project-row').forEach(row => {
                            row.classList.add('expanded');
                            const header = row.querySelector('.project-header');
                            if (header) header.classList.add('expanded');
                        });

                        // 1. Find all epics in the selected month (by end_date ONLY)
                        const epicsInMonth = [];
                        document.querySelectorAll('.month-column').forEach(col => {
                            if (col.dataset.month === selectedMonth) {
                                col.querySelectorAll('.epic-card').forEach(epic => {
                                    epicsInMonth.push(epic);
                                });
                            }
                        });

                        // 2. Get parent projects that have epics in this month
                        const projectsWithEpics = new Set();
                        epicsInMonth.forEach(epic => {
                            const project = epic.closest('.project-row');
                            if (project) projectsWithEpics.add(project);
                        });

                        // 3. Get parent programs that have projects with epics in this month
                        const programsWithEpics = new Set();
                        projectsWithEpics.forEach(project => {
                            const program = project.closest('.program-row');
                            if (program) programsWithEpics.add(program);
                        });

                        // 4. Hide programs that don't have epics in this month (RESPECT PORTFOLIO FILTER)
                        document.querySelectorAll('#execution-view .program-row').forEach(program => {
                            const hasEpicsInMonth = programsWithEpics.has(program);

                            // Check if portfolio filter is active
                            const programPortfolio = program.getAttribute('data-portfolio');
                            const matchesPortfolio = selectedPortfolios.size === 0 || selectedPortfolios.has(programPortfolio);

                            // Show ONLY if has epics in month AND matches portfolio filter
                            program.style.display = (hasEpicsInMonth && matchesPortfolio) ? '' : 'none';
                        });

                        // 5. Hide projects that don't have epics in this month
                        document.querySelectorAll('#execution-view .project-row').forEach(project => {
                            project.style.display = projectsWithEpics.has(project) ? '' : 'none';
                        });

                        // 6. Hide all month columns except the selected month
                        document.querySelectorAll('.month-column').forEach(col => {
                            col.style.display = col.dataset.month === selectedMonth ? '' : 'none';
                        });
                    }
                });
            });
        });

        function switchView(viewName) {
            // Hide all views
            document.querySelectorAll('.view-content').forEach(view => {
                view.classList.remove('active');
            });

            // Deactivate all nav buttons
            document.querySelectorAll('.nav-button').forEach(button => {
                button.classList.remove('active');
            });

            // Show selected view
            const selectedView = document.getElementById(`${viewName}-view`);
            if (selectedView) {
                selectedView.classList.add('active');
            }

            // Activate selected button
            event.target.classList.add('active');

            // Show/hide execution filters
            const executionFilters = document.getElementById('execution-filters-inline');
            if (executionFilters) {
                executionFilters.style.display = viewName === 'execution' ? 'contents' : 'none';
            }

            // Show/hide allocations filters
            const allocationsFilters = document.getElementById('allocations-filters-inline');
            if (allocationsFilters) {
                allocationsFilters.style.display = viewName === 'allocations' ? 'contents' : 'none';
            }

            // Removed: No longer saving active view to localStorage
        }

        // Check if execution view is empty on page load
        document.addEventListener('DOMContentLoaded', () => {
            // Check if execution view is empty
            function checkExecutionEmpty() {
                const treeContainer = document.getElementById('tree-container');
                const emptyState = document.getElementById('execution-empty-state');
                if (treeContainer && emptyState) {
                    const visiblePrograms = document.querySelectorAll('#execution-view .program-row:not([style*="display: none"])');
                    if (visiblePrograms.length === 0) {
                        treeContainer.style.display = 'none';
                        emptyState.style.display = 'block';
                    } else {
                        treeContainer.style.display = '';
                        emptyState.style.display = 'none';
                    }
                }
            }

            // Check on load and after any filter changes
            setTimeout(checkExecutionEmpty, 100);

            // Add mutation observer to detect when filters hide all programs
            const observer = new MutationObserver(checkExecutionEmpty);
            const treeContainer = document.getElementById('tree-container');
            if (treeContainer) {
                observer.observe(treeContainer, { attributes: true, subtree: true, attributeFilter: ['style'] });
            }
        });

        async function refreshData() {
            const button = document.querySelector('.refresh-button');
            button.textContent = 'Refreshing...';
            button.disabled = true;

            try {
                const response = await fetch('/api/refresh');
                const data = await response.json();

                // Reload the page to show fresh data
                window.location.reload();
            } catch (error) {
                console.error('Refresh failed:', error);
                alert('Failed to refresh data. Check console for details.');
            } finally {
                button.textContent = 'Refresh Data';
                button.disabled = false;
            }
        }

        // Toggle program expand/collapse (for Execution tab tree view)
        function toggleProgram(element) {
            const row = element.closest('.program-row');
            const header = element.closest('.program-header');
            row.classList.toggle('expanded');
            header.classList.toggle('expanded');
        }

        // Toggle project expand/collapse (for Execution tab tree view)
        function toggleProject(element) {
            const row = element.closest('.project-row');
            const header = element.closest('.project-header');
            row.classList.toggle('expanded');
            header.classList.toggle('expanded');
        }
    </script>
</body>
</html>