<!-- Stats Cards -->
<div class="stats-grid">
    <!-- Programs Card -->
    <div class="stat-card">
        <div class="stat-header">
            <div class="stat-label">PROGRAMS</div>
            <div class="stat-value">{{ total_execution_programs }}</div>
        </div>
        <div class="stat-rows">

            <div class="stat-row">
                <div class="stat-dot gray"></div>
                <div class="stat-label-text">Not Started</div>
                <div class="stat-bar"><div class="stat-bar-fill gray" style="width: {% if total_execution_programs > 0 %}{{ (health_counts.not_started / total_execution_programs * 100)|round|int }}{% else %}0{% endif %}%"></div></div>
                <div class="stat-percent">{% if total_execution_programs > 0 %}{{ (health_counts.not_started / total_execution_programs * 100)|round|int }}{% else %}0{% endif %}%</div>
                <div class="stat-count">{{ health_counts.not_started }}</div>
            </div>


            <div class="stat-row">
                <div class="stat-dot green"></div>
                <div class="stat-label-text">On Track</div>
                <div class="stat-bar"><div class="stat-bar-fill green" style="width: {% if total_execution_programs > 0 %}{{ (health_counts.on_track / total_execution_programs * 100)|round|int }}{% else %}0{% endif %}%"></div></div>
                <div class="stat-percent">{% if total_execution_programs > 0 %}{{ (health_counts.on_track / total_execution_programs * 100)|round|int }}{% else %}0{% endif %}%</div>
                <div class="stat-count">{{ health_counts.on_track }}</div>
            </div>


            <div class="stat-row">
                <div class="stat-dot orange"></div>
                <div class="stat-label-text">Watch</div>
                <div class="stat-bar"><div class="stat-bar-fill orange" style="width: {% if total_execution_programs > 0 %}{{ (health_counts.watch / total_execution_programs * 100)|round|int }}{% else %}0{% endif %}%"></div></div>
                <div class="stat-percent">{% if total_execution_programs > 0 %}{{ (health_counts.watch / total_execution_programs * 100)|round|int }}{% else %}0{% endif %}%</div>
                <div class="stat-count">{{ health_counts.watch }}</div>
            </div>


            <div class="stat-row">
                <div class="stat-dot red"></div>
                <div class="stat-label-text">Blocked</div>
                <div class="stat-bar"><div class="stat-bar-fill red" style="width: {% if total_execution_programs > 0 %}{{ (health_counts.blocked / total_execution_programs * 100)|round|int }}{% else %}0{% endif %}%"></div></div>
                <div class="stat-percent">{% if total_execution_programs > 0 %}{{ (health_counts.blocked / total_execution_programs * 100)|round|int }}{% else %}0{% endif %}%</div>
                <div class="stat-count">{{ health_counts.blocked }}</div>
            </div>


            <div class="stat-row">
                <div class="stat-dot blue"></div>
                <div class="stat-label-text">Completed</div>
                <div class="stat-bar"><div class="stat-bar-fill blue" style="width: {% if total_execution_programs > 0 %}{{ (health_counts.completed / total_execution_programs * 100)|round|int }}{% else %}0{% endif %}%"></div></div>
                <div class="stat-percent">{% if total_execution_programs > 0 %}{{ (health_counts.completed / total_execution_programs * 100)|round|int }}{% else %}0{% endif %}%</div>
                <div class="stat-count">{{ health_counts.get('completed', 0) }}</div>
            </div>
        </div>
    </div>

    <!-- Projects Card -->
    <div class="stat-card">
        <div class="stat-header">
            <div class="stat-label">PROJECTS</div>
            <div class="stat-value">{{ total_projects }}</div>
        </div>
        <div class="stat-rows">

            <div class="stat-row">
                <div class="stat-dot gray"></div>
                <div class="stat-label-text">Not Started</div>
                <div class="stat-bar"><div class="stat-bar-fill gray" style="width: {% if total_projects > 0 %}{{ (project_stats.not_started / total_projects * 100)|round|int }}{% else %}0{% endif %}%"></div></div>
                <div class="stat-percent">{% if total_projects > 0 %}{{ (project_stats.not_started / total_projects * 100)|round|int }}{% else %}0{% endif %}%</div>
                <div class="stat-count">{{ project_stats.not_started }}</div>
            </div>


            <div class="stat-row">
                <div class="stat-dot green"></div>
                <div class="stat-label-text">On Track</div>
                <div class="stat-bar"><div class="stat-bar-fill green" style="width: {% if total_projects > 0 %}{{ (project_stats.on_track / total_projects * 100)|round|int }}{% else %}0{% endif %}%"></div></div>
                <div class="stat-percent">{% if total_projects > 0 %}{{ (project_stats.on_track / total_projects * 100)|round|int }}{% else %}0{% endif %}%</div>
                <div class="stat-count">{{ project_stats.on_track }}</div>
            </div>


            <div class="stat-row">
                <div class="stat-dot orange"></div>
                <div class="stat-label-text">Watch</div>
                <div class="stat-bar"><div class="stat-bar-fill orange" style="width: {% if total_projects > 0 %}{{ (project_stats.watch / total_projects * 100)|round|int }}{% else %}0{% endif %}%"></div></div>
                <div class="stat-percent">{% if total_projects > 0 %}{{ (project_stats.watch / total_projects * 100)|round|int }}{% else %}0{% endif %}%</div>
                <div class="stat-count">{{ project_stats.watch }}</div>
            </div>


            <div class="stat-row">
                <div class="stat-dot red"></div>
                <div class="stat-label-text">Blocked</div>
                <div class="stat-bar"><div class="stat-bar-fill red" style="width: {% if total_projects > 0 %}{{ (project_stats.blocked / total_projects * 100)|round|int }}{% else %}0{% endif %}%"></div></div>
                <div class="stat-percent">{% if total_projects > 0 %}{{ (project_stats.blocked / total_projects * 100)|round|int }}{% else %}0{% endif %}%</div>
                <div class="stat-count">{{ project_stats.blocked }}</div>
            </div>


            <div class="stat-row">
                <div class="stat-dot blue"></div>
                <div class="stat-label-text">Completed</div>
                <div class="stat-bar"><div class="stat-bar-fill blue" style="width: {% if total_projects > 0 %}{{ (project_stats.completed / total_projects * 100)|round|int }}{% else %}0{% endif %}%"></div></div>
                <div class="stat-percent">{% if total_projects > 0 %}{{ (project_stats.completed / total_projects * 100)|round|int }}{% else %}0{% endif %}%</div>
                <div class="stat-count">{{ project_stats.get('completed', 0) }}</div>
            </div>
        </div>
    </div>

    <!-- Epics Card -->
    <div class="stat-card">
        <div class="stat-header">
            <div class="stat-label">EPICS</div>
            <div class="stat-value">{{ total_epics }}</div>
        </div>
        <div class="stat-rows">

            <div class="stat-row">
                <div class="stat-dot gray"></div>
                <div class="stat-label-text">Not Started</div>
                <div class="stat-bar"><div class="stat-bar-fill gray" style="width: {% if total_epics > 0 %}{{ (epic_stats.not_started / total_epics * 100)|round|int }}{% else %}0{% endif %}%"></div></div>
                <div class="stat-percent">{% if total_epics > 0 %}{{ (epic_stats.not_started / total_epics * 100)|round|int }}{% else %}0{% endif %}%</div>
                <div class="stat-count">{{ epic_stats.not_started }}</div>
            </div>


            <div class="stat-row">
                <div class="stat-dot green"></div>
                <div class="stat-label-text">On Track</div>
                <div class="stat-bar"><div class="stat-bar-fill green" style="width: {% if total_epics > 0 %}{{ (epic_stats.on_track / total_epics * 100)|round|int }}{% else %}0{% endif %}%"></div></div>
                <div class="stat-percent">{% if total_epics > 0 %}{{ (epic_stats.on_track / total_epics * 100)|round|int }}{% else %}0{% endif %}%</div>
                <div class="stat-count">{{ epic_stats.on_track }}</div>
            </div>


            <div class="stat-row">
                <div class="stat-dot orange"></div>
                <div class="stat-label-text">Watch</div>
                <div class="stat-bar"><div class="stat-bar-fill orange" style="width: {% if total_epics > 0 %}{{ (epic_stats.watch / total_epics * 100)|round|int }}{% else %}0{% endif %}%"></div></div>
                <div class="stat-percent">{% if total_epics > 0 %}{{ (epic_stats.watch / total_epics * 100)|round|int }}{% else %}0{% endif %}%</div>
                <div class="stat-count">{{ epic_stats.watch }}</div>
            </div>


            <div class="stat-row">
                <div class="stat-dot red"></div>
                <div class="stat-dot-label-text">Blocked</div>
                <div class="stat-bar"><div class="stat-bar-fill red" style="width: {% if total_epics > 0 %}{{ (epic_stats.blocked / total_epics * 100)|round|int }}{% else %}0{% endif %}%"></div></div>
                <div class="stat-percent">{% if total_epics > 0 %}{{ (epic_stats.blocked / total_epics * 100)|round|int }}{% else %}0{% endif %}%</div>
                <div class="stat-count">{{ epic_stats.blocked }}</div>
            </div>


            <div class="stat-row">
                <div class="stat-dot blue"></div>
                <div class="stat-label-text">Completed</div>
                <div class="stat-bar"><div class="stat-bar-fill blue" style="width: {% if total_epics > 0 %}{{ (epic_stats.completed / total_epics * 100)|round|int }}{% else %}0{% endif %}%"></div></div>
                <div class="stat-percent">{% if total_epics > 0 %}{{ (epic_stats.completed / total_epics * 100)|round|int }}{% else %}0{% endif %}%</div>
                <div class="stat-count">{{ epic_stats.get('completed', 0) }}</div>
            </div>
        </div>
    </div>
</div>



<!-- Empty State (shown when no results match filters) -->
<!-- Empty State -->
<div class="empty-state" id="execution-empty-state" role="status" aria-live="polite" style="display: none;">
    <div class="empty-state-icon">🔍</div>
    <div class="empty-state-title">No Data Found</div>
</div>

