    <!-- Field Service Program Rows -->
    {% for program in execution_programs %}
    <!-- Program Row -->
    <div class="program-row" data-program-id="{{ program.id }}" data-portfolio="{{ program.portfolio }}">
        <div class="program-header" onclick="toggleProgram(this)">
            <div class="expand-icon">▶</div>
            <div class="program-content">
                <a href="https://gus.lightning.force.com/lightning/r/PPM_Program__c/{{ program.id }}/view"
                   target="_blank"
                   class="program-name-link"
                   onclick="event.stopPropagation();"
                   tabindex="-1">{{ program.name }} ↗</a>
                <div class="program-meta-row">
                    <span class="program-meta-badge portfolio-badge">{{ program.portfolio }}</span>
                    <span style="color: #9ca3af; margin: 0 4px;">|</span>
                    <span class="program-meta-badge pm-badge">👤 {{ program.program_manager if program.program_manager else 'TBD' }}</span>

                    <span style="color: #9ca3af; margin: 0 4px;">|</span>
                    <span class="program-meta-badge count-badge">📦 {{ program.projects|length }} Projects</span>
                    <span style="color: #9ca3af; margin: 0 4px;">|</span>
                    {% if program.health_status and program.health_status != 'N/A' %}
                    <span class="program-badge badge-{{ program.health_status|lower|replace(' ', '-') }}">{{ program.health_status }}</span>
                    {% else %}
                    <span class="program-badge badge-not-started">Not Started</span>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Projects Container -->
        <div class="projects-container">
            {% for project in program.projects %}
            <div class="project-section">
                <div class="project-header" onclick="toggleProject(this)">
                    <div class="project-expand-icon">▶</div>
                    <div class="project-name">{{ project.name }}</div>
                    <div class="project-meta">
                        <span class="project-epic-count">{{ project.epics|length }} Epics</span>
                        {% if project.health_status and project.health_status != 'N/A' %}
                        <span class="project-badge badge-{{ project.health_status|lower|replace(' ', '-') }}">{{ project.health_status }}</span>
                        {% else %}
                        <span class="project-badge badge-not-started">Not Started</span>
                        {% endif %}
                    </div>
                </div>
                <div class="epics-container">
                    {% for epic in project.epics %}
                    <div class="epic-row">
                        <span class="epic-name">{{ epic.name }}</span>
                        {% if epic.health_status and epic.health_status != 'N/A' %}
                        <span class="epic-badge badge-{{ epic.health_status|lower|replace(' ', '-') }}">{{ epic.health_status }}</span>
                        {% else %}
                        <span class="epic-badge badge-not-started">Not Started</span>
                        {% endif %}
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endfor %}


    <!-- Allocations Content -->
    <div id="allocations-view" class="view-content">
        <!-- Allocations Tab Content -->

<!-- Stats Grid -->
<div class="stats-grid" style="margin-bottom: 16px;">
    <div class="stat-card">
        <div class="stat-header">
            <div>
                <div class="stat-label">TEAMS</div>
                <div class="stat-value">104</div>
            </div>
        </div>
    </div>
</div>

<!-- By Team View -->
<div id="by-team-view" style="padding: 0px; display: none;">
    <h2 style="font-size: 18px; font-weight: 700; color: #1e293b; margin-bottom: 16px;">Team Capacity</h2>


    <!-- Table with Clean Headers -->
    <div style="overflow-x: auto; max-height: calc(100vh - 300px); overflow-y: auto;">
        <table style="width: 100%; border-collapse: collapse; table-layout: fixed;">
            <thead style="position: sticky; top: 0; z-index: 10;">
                <tr>
                    <th rowspan="2" style="width: 25%; text-align: left; padding: 12px 16px; font-size: 13px; font-weight: 700; color: #475569; text-transform: uppercase; background: #f8fafc; border-radius: 8px 8px 0 0; border-bottom: 2px solid #e5e7eb;">TEAM</th>
                    <th rowspan="2" style="width: 8%; text-align: center; padding: 12px 16px; font-size: 13px; font-weight: 700; color: #475569; text-transform: uppercase; background: #f8fafc; border-radius: 8px 8px 0 0; border-bottom: 2px solid #e5e7eb;">FILLED<br><span style="font-size: 11px; color: #64748b;">(HC)</span></th>
                    <th rowspan="2" style="width: 12%; text-align: center; padding: 12px 16px; font-size: 13px; font-weight: 700; color: #475569; text-transform: uppercase; background: #f8fafc; border-radius: 8px 8px 0 0; border-bottom: 2px solid #e5e7eb;">MONTHLY CAPACITY<br><span style="font-size: 11px; color: #64748b;">(PD)</span></th>
                    
                    
                    

